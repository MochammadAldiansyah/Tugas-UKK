{
  "version": 2,
  "builds": [
    {
      "src": "antrianbarang/wsgi.py",
      "use": "@vercel/python@latest",
      "config": { 
        "maxLambdaSize": "15mb", 
        "runtime": "python3.12"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "antrianbarang/wsgi.py"
    }
  ],
  "env": {
    "PYTHONUNBUFFERED": "1"
  }
}