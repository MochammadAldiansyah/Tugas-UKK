{
  "version": 2,
  "builds": [
    {
      "src": "antrianbarang/wsgi.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb", "runtime": "python3.11" }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "antrianbarang/wsgi.py"
    }
  ],
  "installCommand": "pip install -r requirements.txt"
}